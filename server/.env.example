PORT=4000
SERVER_URL=http://localhost:4000
DATABASE_URL=postgresql://postgres:<password>@localhost:5432/apsara_style_db
ADMIN_KEY=your-admin-key
ADMIN_TOKEN_SECRET=your-admin-jwt-secret
USER_TOKEN_SECRET=your-user-jwt-secret
CLIENT_URL=http://localhost:5173
EMAIL_MODE=console
# SMTP settings (required when EMAIL_MODE=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=APSARA STYLE <no-reply@apsara.local>
BAKONG_MERCHANT_ID=APSARA-STYLE
BAKONG_MERCHANT_NAME=APSARA STYLE
BAKONG_CURRENCY=USD
BAKONG_STATUS_URL=
BAKONG_STATUS_METHOD=GET
BAKONG_API_KEY=
BAKONG_WEBHOOK_SECRET=
ADMIN_ACCESS_TOKEN_EXPIRES_SEC=28800
ADMIN_REFRESH_TOKEN_EXPIRES_DAYS=14
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Upload storage: local | cloudinary
UPLOAD_STORAGE=local

# Cloudinary (required only when UPLOAD_STORAGE=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=apsara-style/products
